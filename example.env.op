# Секреты проекта — ссылки на 1Password items.
# Формат: обычный shell export, значение — op-ссылка на поле item.
# `op inject` заменяет ссылки на реальные значения.
#
# ВАЖНО (см. README → Подводные камни):
#   - каждая строка ДОЛЖНА начинаться с export, иначе переменной не будет в окружении;
#   - НЕ упоминай op-ссылки в комментариях — op inject пытается их резолвить и падает.

export GITHUB_TOKEN="op://VaultName/item-name/field"
export DB_PASSWORD="op://VaultName/database/password"
